# ============================================================
# SUNBOO経営ナビ — 環境変数テンプレート
# ============================================================
# このファイルをコピーして .env.local を作成してください。
# cp .env.local.example .env.local
#
# Supabase 未設定でも開発サーバーは起動しますが、
# 診断結果・手続き一覧・管轄機関一覧にデータは表示されません。
# ============================================================

# --- Supabase ---------------------------------------------------
# 取得方法: https://supabase.com → プロジェクト → Settings → API
#
# Project URL（例: https://abcdefghijkl.supabase.co）
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
#
# anon public key（公開可能な匿名キー）
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# --- 本番URL（Phase8 Release Infrastructure）---------------------
# robots.txt・sitemap.xml・canonical/OGPの絶対URL生成に使用（src/lib/siteUrl.ts）。
# 未設定の場合はVercelのVERCEL_URL（プレビュー/本番のデプロイURL）で自動的に代用されるため、
# 本番ドメインを確定させるまでは設定しなくても動作する。本番ドメイン確定後に必ず設定すること。
# NEXT_PUBLIC_SITE_URL=https://your-production-domain.example.com

# --- 将来の拡張用（現在は未使用）--------------------------------
# Stripe 決済（Phase 7 以降）
# STRIPE_SECRET_KEY=sk_live_...
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
#
# Resend メール（Phase 6 以降）
# RESEND_API_KEY=re_...
